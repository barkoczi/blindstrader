      APP_URL: https://brand.{{ domain }}
      DB_HOST: db
      DB_PORT: 3306
      DB_DATABASE: blindstrader_brand
      DB_USERNAME: ${DB_USERNAME}
      DB_PASSWORD: ${DB_PASSWORD}
      REDIS_HOST: redis
      REDIS_PORT: 6379
{% if redis_password_secret.stdout %}
      REDIS_PASSWORD: ${REDIS_PASSWORD}
{% endif %}
      SESSION_DRIVER: redis
      CACHE_STORE: redis
