# ─── API Docs Portal (Scalar) ─────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name docs.{{ domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location / {
        proxy_pass         http://docs:80;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}

# ─── Root domain → Identity ───────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;

    return 301 https://identity.{{ domain }}$request_uri;
}

# ─── Retailer Storefront — Dynamic Tenant Routing (OpenResty Lua + Redis) ────
# Catch-all for custom retailer domains not matching *.{{ domain }}
# Redis key: "domain:{hostname}" → "{tenant_id}"
# Populated when a Retailer links a custom domain in the Platform admin.
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
    server_name _;

    # Fallback cert — per-domain certs provisioned separately via certbot
    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    root  /app/retailer/public;
    index index.php;

    set $tenant_id "";

    access_by_lua_block {
        local redis  = require "resty.redis"
        local cache  = ngx.shared.tenant_cache
        local host   = ngx.var.host

        local tenant_id = cache:get(host)

        if not tenant_id then
            local red = redis:new()
            red:set_timeouts(500, 500, 500)

            local ok, err = red:connect("redis", 6379)
            if not ok then
                ngx.log(ngx.ERR, "[storefront] Redis connect error: ", err)
                return ngx.exit(503)
            end

            local pass = os.getenv("REDIS_PASSWORD")
            if pass and pass ~= "" then
                local res, auth_err = red:auth(pass)
                if not res then
                    ngx.log(ngx.ERR, "[storefront] Redis auth error: ", auth_err)
                    return ngx.exit(503)
                end
            end

            local val, get_err = red:get("domain:" .. host)
            red:set_keepalive(10000, 100)

            if get_err then
                ngx.log(ngx.ERR, "[storefront] Redis GET error: ", get_err)
                return ngx.exit(503)
            end

            if not val or val == ngx.null then
                ngx.log(ngx.WARN, "[storefront] No tenant for domain: ", host)
                ngx.status  = 404
                ngx.header["Content-Type"] = "text/html; charset=utf-8"
                ngx.say("<h1>Storefront not found</h1>")
                return ngx.exit(404)
            end

            tenant_id = val
            cache:set(host, tenant_id, 60)
        end

        ngx.var.tenant_id = tenant_id
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass  retailer:9000;
        fastcgi_index index.php;
        include       fastcgi_params;
        fastcgi_param SCRIPT_FILENAME     $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO           $fastcgi_path_info;
        fastcgi_param HTTP_X_TENANT_ID    $tenant_id;
        fastcgi_param HTTP_X_FORWARDED_HOST $host;
    }

    location ~ /\.(?!well-known).* { deny all; }
}
