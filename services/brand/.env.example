APP_NAME=Brand
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://brand.blindstrader.test
APP_PORT=8002

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=blindstrader_brand
DB_USERNAME=blindstrader
DB_PASSWORD=blindstrader

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Session
SESSION_LIFETIME=120
SESSION_DOMAIN=.blindstrader.test
SANCTUM_STATEFUL_DOMAINS=

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=brand
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SEND_DEFAULT_PII=true

# Inter-service Auth (issued by Identity service)
IDENTITY_SERVICE_URL=http://identity:9000
SERVICE_ACCOUNT_CLIENT_ID=
SERVICE_ACCOUNT_CLIENT_SECRET=

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=brand-service
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Tenancy (stancl/tenancy)
TENANCY_DB_HOST=db
TENANCY_DB_PORT=3306
TENANCY_DB_USERNAME=blindstrader
TENANCY_DB_PASSWORD=blindstrader
TENANCY_DB_PREFIX=blindstrader_brand_

# Mail (for notifications / password resets)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@blindstrader.com"
MAIL_FROM_NAME="${APP_NAME}"
